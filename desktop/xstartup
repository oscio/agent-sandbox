#!/bin/sh
# Launched by KasmVNC for each VNC session. Runs as `coder`.
# Brings up the X session + ibus daemon for Korean input. The
# GTK/Qt IM env vars below are inherited by every app XFCE
# spawns (file manager, browsers, terminals), so Hangul typing
# works without per-app config.
xrdb $HOME/.Xresources 2>/dev/null || true
export XDG_SESSION_DESKTOP=xfce
export XDG_CURRENT_DESKTOP=XFCE
export GTK_IM_MODULE=ibus
export QT_IM_MODULE=ibus
export XMODIFIERS=@im=ibus
# ibus-daemon flags: -d daemonize, -r replace running daemon, -x XIM.
ibus-daemon -drx &
exec dbus-launch --exit-with-session xfce4-session
